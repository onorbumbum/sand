### Non-root interactive Sandbox Session evidence

$ container exec --tty --user sandbox --workdir /workspace sand-validation-spike bash -lc tty; whoami; pwd
/dev/pts/0
sandbox
/workspace
[exit 0]

$ container exec --user sandbox sand-validation-spike bash -lc id && test "$(whoami)" = sandbox
uid=1001(sandbox) gid=1001(sandbox) groups=1001(sandbox)
[exit 0]


### Passwordless sudo inside Sandbox Guest

$ container exec --user sandbox sand-validation-spike bash -lc sudo -n whoami && test "$(sudo -n whoami)" = root
root
[exit 0]

$ container exec --user sandbox sand-validation-spike bash -lc sudo -n install -d -o sandbox -g sandbox /state/sandbox && test -w /state/sandbox
[exit 0]


### Read-write Allowed Folder and Host-Safe File Ownership

$ container exec --user sandbox --workdir /workspace/rw sand-validation-spike bash -lc echo guest-created > guest-created.txt && echo guest-modified >> host-owned.txt && pwd
/workspace/rw
[exit 0]

$ ls -lna /tmp/sand-backend-validation/rw
total 16
drwxr-xr-x@ 5 501  0  160 May 18 22:09 .
drwxr-xr-x@ 4 501  0  128 May 18 22:09 ..
-rw-r--r--  1 501  0   14 May 18 22:09 guest-created.txt
-rw-r--r--@ 1 501  0   29 May 18 22:09 host-owned.txt
drwxr-xr-x@ 2 501  0   64 May 18 22:09 subdir
[exit 0]

$ cat /tmp/sand-backend-validation/rw/guest-created.txt /tmp/sand-backend-validation/rw/host-owned.txt
guest-created
host-original
guest-modified
[exit 0]

$ test "$(stat -f '%u' '/tmp/sand-backend-validation/rw/guest-created.txt')" = '501'
[exit 0]

$ test "$(stat -f '%u' '/tmp/sand-backend-validation/rw/host-owned.txt')" = '501'
[exit 0]


### Read-only Allowed Folder blocks writes

$ container exec --user sandbox --workdir /workspace/ro 'sand-validation-spike' bash -lc 'echo should-fail > blocked.txt' && exit 1 || exit 0
bash: line 1: blocked.txt: Read-only file system
[exit 0]

$ test ! -e '/tmp/sand-backend-validation/ro/blocked.txt'
[exit 0]


### Working Directory Mapping can start inside mounted folder

$ container exec --user sandbox --workdir /workspace/rw/subdir sand-validation-spike bash -lc pwd && echo mapped > mapped.txt
/workspace/rw/subdir
[exit 0]

$ cat /tmp/sand-backend-validation/rw/subdir/mapped.txt
mapped
[exit 0]


### Persistent Guest State survives stop/start

$ container exec --user sandbox sand-validation-spike bash -lc echo before-stop > /state/sandbox/persistent.txt
[exit 0]

$ container stop sand-validation-spike
sand-validation-spike
[exit 0]

$ container start sand-validation-spike
sand-validation-spike
[exit 0]

$ container exec --user sandbox sand-validation-spike bash -lc cat /state/sandbox/persistent.txt && test "$(cat /state/sandbox/persistent.txt)" = before-stop
before-stop
[exit 0]


### Multiple Sandbox Sessions can run concurrently

$ container exec --detach --user sandbox sand-validation-spike bash -lc sleep 3; echo session-one > /state/sandbox/session-one.txt
sand-validation-spike
[exit 0]

$ container exec --detach --user sandbox sand-validation-spike bash -lc sleep 3; echo session-two > /state/sandbox/session-two.txt
sand-validation-spike
[exit 0]

$ container exec --user sandbox sand-validation-spike bash -lc pgrep -a sleep || true
1 sleep 10000
8 sleep 3
11 sleep 3
[exit 0]

$ sleep 5
[exit 0]

$ container exec --user sandbox sand-validation-spike bash -lc cat /state/sandbox/session-one.txt /state/sandbox/session-two.txt
session-one
session-two
[exit 0]


